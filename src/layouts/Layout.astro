---
import "../styles/global.css";
import Container from "../components/layout/Container.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Content from "../components/layout/Content.astro";
import Head from "../components/layout/Head.astro";
import type { Props as HeaderProps } from "../components/layout/Header.astro";
import type { Props as HeadProps } from "../components/layout/Head.astro";

type Props = HeadProps &
  HeaderProps & {
    class?: string[];
  };
const {
  title,
  description,
  siteTitle,
  siteDescription,
  siteDescriptionHtml,
  arenaChannelUrl,
  class: className,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <Head
    title={title}
    description={description}
    siteTitle={siteTitle}
    siteDescription={siteDescription}
  />

  <body id="clippings-myles-garden" class:list={[className]}>
    <Container>
      <Header
        siteTitle={siteTitle}
        siteDescriptionHtml={siteDescriptionHtml}
        arenaChannelUrl={arenaChannelUrl}
      />
      <Content>
        <slot />
      </Content>
      <Footer />
    </Container>
  </body>
</html>
