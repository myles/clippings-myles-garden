---
import "../styles/global.css";
import Container from "../components/layout/Container.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Content from "../components/layout/Content.astro";
import type { Props as HeaderProps } from "../components/layout/Header.astro";

type Props = HeaderProps & {
  title?: string;
  description?: string;
  class?: string[];
};
const {
  title,
  description,
  siteTitle,
  siteDescription,
  class: className,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width,initial-scale=1,viewport-fit=cover"
    />
    <meta name="generator" content={Astro.generator} />

    <title>{title && `${title} | `}{siteTitle}</title>
    <meta name="description" content={description || siteDescription} />

    <link
      rel="alternate"
      title={`${siteTitle} JSON Feed`}
      type="application/feed+json"
      href={new URL("/feed.json", Astro.site).href}
    />
    <link
      rel="alternate"
      title={`${siteTitle} RSS Feed`}
      type="application/rss+xml"
      href={new URL("/feed.xml", Astro.site).href}
    />
  </head>
  <body id="clippings-myles-garden" class:list={[className]}>
    <Container>
      <Header siteTitle={siteTitle} siteDescription={siteDescription} />
      <Content>
        <slot />
      </Content>
      <Footer />
    </Container>
  </body>
</html>
