---
import type { BlockBase } from "@/lib/schemas/block-schema.types";
import BlockImageLarge from "../shared/BlockImageLarge.astro";

type Props = {
  block: BlockBase<"Image">;
  class?: string[];
};
const { block, class: className } = Astro.props;
---

<BlockImageLarge
  image={block.data.image}
  href={block.data.source?.url}
  isExternal
  class:list={["block-detail-image", className]}
/>
