---
import type { BlockBase } from "@/lib/schemas";
import BlockImageLarge from "../shared/BlockImageLarge.astro";

type Props = {
  block: BlockBase<"Image">;
};

const { block } = Astro.props;
---

<BlockImageLarge
  image={block.data.image}
  href={block.data.source?.url ?? block.data.image.src}
  isExternal
/>
