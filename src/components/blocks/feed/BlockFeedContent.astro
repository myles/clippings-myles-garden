---
import {
  isAttachmentBlock,
  isChannelBlock,
  isEmbedBlock,
  isImageBlock,
  isLinkBlock,
  isTextBlock,
} from "@/lib/content";
import type { Block } from "@/lib/schemas";
import BlockFeedContentAttachment from "./BlockFeedContentAttachment.astro";
import BlockFeedContentChannel from "./BlockFeedContentChannel.astro";
import BlockFeedContentEmbed from "./BlockFeedContentEmbed.astro";
import BlockFeedContentImage from "./BlockFeedContentImage.astro";
import BlockFeedContentLink from "./BlockFeedContentLink.astro";
import BlockFeedContentText from "./BlockFeedContentText.astro";

type Props = {
  block: Block;
};

const { block } = Astro.props;

let Component;
switch (true) {
  case isAttachmentBlock(block):
    Component = BlockFeedContentAttachment;
    break;
  case isChannelBlock(block):
    Component = BlockFeedContentChannel;
    break;
  case isEmbedBlock(block):
    Component = BlockFeedContentEmbed;
    break;
  case isImageBlock(block):
    Component = BlockFeedContentImage;
    break;
  case isLinkBlock(block):
    Component = BlockFeedContentLink;
    break;
  case isTextBlock(block):
    Component = BlockFeedContentText;
    break;
  default:
    console.warn(`Unsupported block type: ${block.data.type}`);
    break;
}
---

{Component && <Component block={block as any} />}
