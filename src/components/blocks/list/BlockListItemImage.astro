---
import { Picture } from "astro:assets";
import type { BlockBase } from "../../../lib/schemas/block-schema.types";

type Props = {
  block: BlockBase<"Image">;
  class?: string[];
};
const { block, class: className } = Astro.props;

const width = block.data.image.square.width ?? 768;
const height = block.data.image.square.height ?? 768;
---

<Fragment>
  <Picture
    src={block.data.image.src}
    alt={block.data.image.alt_text ?? ""}
    width={width}
    height={height}
    widths={[384, 768, 1536]}
    sizes={`(max-width: 1536px) 384px, 768px, 1536px, 100vh`}
    formats={["avif", "webp"]}
    class:list={["w-full h-full object-contain", className]}
    pictureAttributes={{ class: "contents" }}
  />
</Fragment>
